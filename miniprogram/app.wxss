page {
  height: 100%;
  background: #fff8f5;
  color: #1f2937;
  font-size: 28rpx;
  box-sizing: border-box;
  --td-brand-color: #ff6b4a;
  --td-warning-color: #d97706;
  --td-success-color: #059669;
  --td-radius-default: 24rpx;
}

.page-root {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  padding: 24rpx 32rpx 0;
  box-sizing: border-box;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.page-subtitle {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.scroll-body {
  flex: 1;
  height: 0;
  min-height: 0;
}

.settings-entry {
  padding: 8rpx;
  font-size: 26rpx;
  color: #6b7280;
}
