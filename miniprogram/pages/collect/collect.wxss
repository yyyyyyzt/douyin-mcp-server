.page { padding: 32rpx; }
.hero { margin-bottom: 24rpx; color: #6b7280; }
.input {
  width: 100%;
  min-height: 200rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.row { margin-bottom: 24rpx; }
.progress { margin-top: 32rpx; color: #6b7280; }
.error { color: #dc2626; margin-top: 24rpx; }
.preview {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
}
.preview-title { font-weight: 600; display: block; margin-bottom: 12rpx; }
.preview-body { color: #4b5563; }
