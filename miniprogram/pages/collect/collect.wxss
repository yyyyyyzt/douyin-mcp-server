.collect-textarea {
  background: #fff;
  border-radius: 24rpx;
  padding: 16rpx;
  min-height: 200rpx;
}

.actions {
  margin: 16rpx 0 24rpx;
}

.progress-block {
  margin-top: 32rpx;
}

.progress-label {
  display: block;
  margin-bottom: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.error-text {
  margin-top: 24rpx;
  color: #dc2626;
  font-size: 26rpx;
  line-height: 1.5;
}

.preview-cell {
  margin-top: 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
