<view class="page-root">
  <view class="page-header">
    <view>
      <view class="page-title">收集</view>
      <view class="page-subtitle">把刷到的装修经验存成自己的知识</view>
    </view>
    <view class="settings-entry" bindtap="goSettings">
      <t-icon name="setting" size="44rpx" color="#6b7280" />
    </view>
  </view>

  <scroll-view class="scroll-body" scroll-y enhanced show-scrollbar="{{false}}">
    <t-textarea
      value="{{input}}"
      placeholder="粘贴抖音分享链接或装修笔记"
      maxlength="-1"
      autosize="{{true}}"
      disableDefaultPadding="{{true}}"
      bind:change="onInput"
      t-class="collect-textarea"
    />

    <view class="actions">
      <t-button theme="light" variant="outline" size="small" bind:tap="pasteClipboard">粘贴</t-button>
    </view>

    <t-button
      theme="primary"
      size="large"
      block
      loading="{{busy}}"
      disabled="{{busy}}"
      bind:tap="onSave"
    >保存到知识库</t-button>

    <view wx:if="{{busy}}" class="progress-block">
      <text class="progress-label">{{stepLabel}}</text>
      <t-progress percentage="{{progress}}" stroke-width="8" color="#FF6B4A" />
    </view>

    <view wx:if="{{error}}" class="error-text">{{error}}</view>

    <t-cell
      wx:if="{{lastCard}}"
      title="{{lastCard.title || '未命名'}}"
      description="{{lastCard.raw_text}}"
      hover
      class="preview-cell"
    />
  </scroll-view>
</view>
