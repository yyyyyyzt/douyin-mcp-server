<view class="page safe-bottom">
  <view wx:if="{{!messages.length}}" class="quick">
    <view class="hint">试试这些问题：</view>
    <view
      wx:for="{{quickQuestions}}"
      wx:key="*this"
      class="quick-item"
      data-q="{{item}}"
      bindtap="askQuick"
    >{{item}}</view>
  </view>

  <scroll-view scroll-y class="chat" scroll-into-view="bottom">
    <block wx:for="{{messages}}" wx:key="index">
      <view class="msg {{item.role}}">
        <text>{{item.content}}{{item.pending ? '…' : ''}}</text>
        <view wx:if="{{item.role === 'assistant' && !item.pending && item.grounded}}" class="badge ok">来自你的知识库</view>
        <view wx:if="{{item.role === 'assistant' && !item.pending && !item.grounded}}" class="badge warn">没找到你的知识依据，仅供参考</view>
      </view>
    </block>
    <view id="bottom"></view>
  </scroll-view>

  <view wx:if="{{document}}" class="doc">
  已选：{{document.filename}}
    <text bindtap="clearDoc">移除</text>
  </view>

  <view class="composer">
    <button size="mini" bindtap="chooseFile">附件</button>
    <input class="composer-input" value="{{input}}" bindinput="onInput" confirm-type="send" bindconfirm="send" />
    <button class="send" loading="{{loading}}" bindtap="send">发送</button>
  </view>
</view>
