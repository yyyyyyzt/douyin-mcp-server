<view class="page-root chat-page">
  <login-guard visible="{{needLogin}}" bind:success="onLoginSuccess" />
  <block wx:if="{{!needLogin}}">
    <view class="chat-topbar">
      <view class="chat-topbar-title">AI 助手</view>
      <view class="chat-topbar-action" bindtap="goSettings">设置</view>
    </view>

    <scroll-view
      class="scroll-body chat-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollIntoView}}"
      scroll-with-animation
    >
      <view wx:if="{{!messages.length}}" class="welcome">
        <view class="welcome-brand">自装助手</view>
        <view class="welcome-text">基于你收藏的装修知识回答，有依据才敢用。</view>
        <view class="chip-row">
          <view
            wx:for="{{scenarios}}"
            wx:key="id"
            class="chip {{item.enabled ? '' : 'chip-disabled'}}"
            data-id="{{item.id}}"
            bindtap="onScenarioTap"
          >{{item.label}}</view>
        </view>
      </view>

      <block wx:for="{{messages}}" wx:key="id">
        <chat-message message="{{item}}" />
      </block>
      <view id="chat-bottom" class="scroll-anchor"></view>
    </scroll-view>

    <view class="composer-shell">
      <view wx:if="{{attachment}}" class="attachment-bar">
        <text class="attach-name">{{attachment.filename}}</text>
        <text class="clear-attach" bindtap="clearAttachment">移除</text>
      </view>
      <view class="composer-box">
        <view class="attach-btn" bindtap="chooseFile">＋</view>
        <textarea
          class="composer-input"
          value="{{input}}"
          placeholder="问点装修相关的…"
          auto-height
          maxlength="-1"
          confirm-type="send"
          adjust-position="{{true}}"
          show-confirm-bar="{{false}}"
          cursor-spacing="48"
          bindinput="onInput"
          bindconfirm="onSendConfirm"
        />
        <button
          class="send-btn {{canSend ? 'ready' : ''}}"
          bindtap="send"
          disabled="{{!canSend || loading}}"
          loading="{{loading}}"
        >发送</button>
      </view>
    </view>
  </block>
</view>
