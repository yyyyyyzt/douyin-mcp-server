.chat-page {
  padding-bottom: 0;
}

.chat-scroll {
  padding-bottom: 16rpx;
}

.scenario-panel {
  padding-bottom: 24rpx;
}

.scenario-hint {
  color: #9ca3af;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.scenario-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  color: #374151;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.scenario-item.disabled {
  opacity: 0.72;
}

.composer-bar {
  flex-shrink: 0;
  padding: 16rpx 0 24rpx;
  background: #fff8f5;
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
}

.attachment-bar {
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.clear-attach {
  color: #ff6b4a;
  font-size: 26rpx;
}

.composer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.attach-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
}

.composer-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 999rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.scroll-anchor {
  height: 1rpx;
}
