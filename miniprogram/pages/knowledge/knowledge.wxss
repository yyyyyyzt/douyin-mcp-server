.search-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.search-clear {
  color: #9ca3af;
  font-size: 24rpx;
  padding: 8rpx;
}

.stage-scroll {
  flex-shrink: 0;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.stage-row {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.stage-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #6b7280;
  font-size: 26rpx;
  border: 2rpx solid #ece7e2;
}

.stage-chip.active {
  background: #ff6b4a;
  color: #fff;
  border-color: #ff6b4a;
}

.chip-count {
  font-size: 22rpx;
  opacity: 0.85;
}

.loading-wrap,
.empty-box {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #9ca3af;
}

.empty-title {
  font-size: 32rpx;
  color: #374151;
  font-weight: 600;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.empty-btn {
  margin-top: 32rpx;
  display: inline-block;
  background: #ff6b4a;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0 40rpx;
  line-height: 72rpx;
}

.empty-btn::after {
  border: none;
}

.section {
  margin-bottom: 28rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.card-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.04);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.card-manage {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #ff6b4a;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #ffede8;
}

.card-excerpt {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-meta {
  margin-top: 12rpx;
}

.card-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #ff6b4a;
  background: #ffede8;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 1200;
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  width: 100%;
  max-height: 86vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.sheet-header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.sheet-close {
  font-size: 26rpx;
  color: #6b7280;
  padding: 8rpx 4rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.detail-stage {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #ff6b4a;
  flex-shrink: 0;
}

.detail-body {
  margin-top: 20rpx;
  flex: 1;
  min-height: 0;
  max-height: 52vh;
}

.edit-scroll {
  flex: 1;
  min-height: 0;
  max-height: 58vh;
}

.field-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.detail-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  flex-shrink: 0;
}

.sheet-btn {
  flex: 1;
  margin: 0;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  height: 80rpx;
  padding: 0;
}

.sheet-btn::after {
  border: none;
}

.sheet-btn.ghost {
  background: #f3f4f6;
  color: #374151;
}

.sheet-btn.danger {
  background: #fff1f2;
  color: #dc2626;
}

.sheet-btn.primary {
  background: #ff6b4a;
  color: #fff;
}

.sheet-btn.block {
  width: 100%;
  margin-top: 20rpx;
}

.detail-input {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.stage-picker {
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  color: #374151;
}

.detail-textarea {
  width: 100%;
  min-height: 280rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.settings-entry {
  font-size: 26rpx;
  color: #6b7280;
  padding: 12rpx 8rpx;
}
