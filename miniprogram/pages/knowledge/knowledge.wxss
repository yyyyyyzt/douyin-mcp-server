.kb-search {
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.stage-scroll {
  flex-shrink: 0;
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.stage-row {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.stage-tag {
  flex-shrink: 0;
}

.loading-wrap {
  padding: 80rpx 0;
  display: flex;
  justify-content: center;
}

.card-cell {
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.detail-sheet {
  padding: 32rpx;
  max-height: 72vh;
  box-sizing: border-box;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.detail-body {
  max-height: 40vh;
  color: #374151;
  line-height: 1.6;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.detail-input {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
