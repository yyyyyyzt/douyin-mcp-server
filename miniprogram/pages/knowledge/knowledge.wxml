<view class="page-root">
  <login-guard visible="{{needLogin}}" bind:success="onLoginSuccess" />
  <block wx:if="{{!needLogin}}">
    <page-user-bar bind:logout="onUserLogout" />
    <view class="page-header">
      <view>
        <view class="page-title">知识库</view>
        <view class="page-subtitle">浏览你收藏的装修知识</view>
      </view>
      <view class="settings-entry" bindtap="goSettings">设置</view>
    </view>

    <view class="search-wrap">
      <input
        class="search-input"
        value="{{search}}"
        placeholder="搜索标题或正文…"
        confirm-type="search"
        bindinput="onSearchChange"
      />
      <text wx:if="{{search}}" class="search-clear" bindtap="onSearchClear">清除</text>
    </view>

    <scroll-view class="scroll-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{loading}}" class="loading-wrap">加载中…</view>

      <view wx:elif="{{!displayCards.length}}" class="empty-box">
        <view class="empty-title">还没有知识</view>
        <view class="empty-desc">去收集页保存第一条装修经验</view>
        <button class="empty-btn" bindtap="goCollect">去收集</button>
      </view>

      <block wx:else>
        <view
          wx:for="{{displayCards}}"
          wx:key="id"
          class="card-item"
          data-id="{{item.id}}"
          bindtap="openDetail"
          bindlongpress="openCardMenu"
        >
          <view class="card-head">
            <view class="card-title">{{item.title || '未命名'}}</view>
            <view
              class="card-manage"
              data-id="{{item.id}}"
              catchtap="openCardMenu"
            >管理</view>
          </view>
          <view class="card-excerpt">{{item.excerpt}}</view>
        </view>
      </block>
    </scroll-view>

    <view wx:if="{{detailVisible}}" class="sheet-mask" bindtap="closeDetail">
      <view class="detail-sheet" catchtap="noop">
        <view class="sheet-header">
          <text class="sheet-header-title">{{editing ? '编辑知识' : '知识详情'}}</text>
          <text class="sheet-close" catchtap="closeDetail">关闭</text>
        </view>

        <block wx:if="{{!editing}}">
          <view class="detail-title">{{detail.title || '未命名'}}</view>
          <scroll-view scroll-y class="detail-body" enhanced show-scrollbar="{{false}}">
            <rich-text nodes="{{detailHtml}}" />
          </scroll-view>
          <view class="detail-actions">
            <button class="sheet-btn primary" bindtap="toggleEdit">编辑</button>
            <button class="sheet-btn danger" bindtap="deleteDetail">删除</button>
          </view>
        </block>

        <block wx:else>
          <scroll-view scroll-y class="edit-scroll" enhanced show-scrollbar="{{false}}">
            <view class="field-label">标题</view>
            <input class="detail-input" value="{{editTitle}}" bindinput="onEditTitle" placeholder="给这条知识起个标题" />
            <view class="field-label">正文（支持 Markdown）</view>
            <textarea
              class="detail-textarea"
              value="{{editBody}}"
              bindinput="onEditBody"
              maxlength="-1"
              auto-height
              placeholder="写下要点、步骤或注意事项…"
            />
          </scroll-view>
          <view class="detail-actions">
            <button class="sheet-btn ghost" bindtap="cancelEdit">取消</button>
            <button class="sheet-btn primary" bindtap="saveDetail">保存</button>
          </view>
        </block>
      </view>
    </view>
  </block>
</view>
