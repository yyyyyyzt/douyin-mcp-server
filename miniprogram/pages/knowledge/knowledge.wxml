<view class="page-root">
  <login-guard visible="{{needLogin}}" bind:success="onLoginSuccess" />
  <block wx:if="{{!needLogin}}">
  <view class="page-header">
    <view>
      <view class="page-title">知识库</view>
      <view class="page-subtitle">像备忘录一样查看装修知识</view>
    </view>
    <view class="settings-entry" bindtap="goSettings">
      <t-icon name="setting" size="44rpx" color="#6b7280" />
    </view>
  </view>

  <t-search
    value="{{search}}"
    placeholder="搜防水、报价、验收..."
    bind:change="onSearchChange"
    bind:clear="onSearchClear"
    class="kb-search"
  />

  <scroll-view class="stage-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="stage-row">
      <t-tag
        wx:for="{{stages}}"
        wx:key="*this"
        variant="{{stage === item ? 'dark' : 'light'}}"
        theme="{{stage === item ? 'primary' : 'default'}}"
        class="stage-tag"
        data-stage="{{item}}"
        bind:tap="onStageTap"
      >{{item}}</t-tag>
    </view>
  </scroll-view>

  <scroll-view class="scroll-body" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="loading-wrap">
      <t-loading theme="circular" size="48rpx" />
    </view>

    <t-empty
      wx:elif="{{!filtered.length}}"
      icon="info-circle-filled"
      description="还没有知识，去收集第一个装修经验"
    >
      <t-button theme="primary" size="small" bind:tap="goCollect">去收集</t-button>
    </t-empty>

    <t-cell
      wx:for="{{filtered}}"
      wx:key="id"
      title="{{item.title || '未命名'}}"
      description="{{item.excerpt}}"
      hover
      arrow
      data-id="{{item.id}}"
      bind:click="openDetail"
      class="card-cell"
    />
  </scroll-view>

  <t-popup
    visible="{{detailVisible}}"
    placement="bottom"
    bind:visible-change="onPopupVisibleChange"
  >
    <view class="detail-sheet">
      <block wx:if="{{!editing}}">
        <view class="detail-title">{{detail.title}}</view>
        <scroll-view scroll-y class="detail-body" enhanced show-scrollbar="{{false}}">
          <rich-text nodes="{{detailHtml}}" />
        </scroll-view>
        <view class="detail-actions">
          <t-button theme="light" size="medium" bind:tap="toggleEdit">编辑</t-button>
          <t-button theme="danger" variant="outline" size="medium" bind:tap="deleteDetail">删除</t-button>
          <t-button theme="primary" size="medium" bind:tap="closeDetail">关闭</t-button>
        </view>
      </block>
      <block wx:else>
        <input class="detail-input" value="{{editTitle}}" bindinput="onEditTitle" placeholder="标题" />
        <t-textarea value="{{editBody}}" bind:change="onEditBody" autosize="{{true}}" maxlength="-1" />
        <t-button theme="primary" block bind:tap="saveDetail">保存</t-button>
      </block>
    </view>
  </t-popup>
  </block>
</view>
