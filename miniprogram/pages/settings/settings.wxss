.settings-page {
  min-height: 100%;
  box-sizing: border-box;
  padding: 24rpx 28rpx 64rpx;
  background: #f7f4f1;
}

.hero {
  margin-bottom: 24rpx;
  padding: 8rpx 4rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.55;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.row:last-of-type {
  border-bottom: none;
}

.label {
  flex-shrink: 0;
  color: #6b7280;
  font-size: 26rpx;
}

.value {
  flex: 1;
  text-align: right;
  color: #1f2937;
  font-size: 26rpx;
  word-break: break-all;
}

.value.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 22rpx;
}

.value.ok {
  color: #059669;
}

.value.bad {
  color: #dc2626;
}

.action,
.reset {
  margin: 20rpx 0 0;
  background: #ffede8;
  color: #ff6b4a;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  height: 80rpx;
  border: none;
}

.action::after,
.reset::after {
  border: none;
}

.reset {
  background: #fff;
  color: #6b7280;
  border: 2rpx solid #e5e7eb;
}

.option {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
}

.option.selected {
  background: #fff8f5;
  border-color: #ffd5c8;
}

.option-body {
  flex: 1;
}

.option-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.option-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.4;
}

.note {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-top: 8rpx;
}
