<view class="chat-message {{message.role}}">
  <!-- 用户消息 -->
  <view wx:if="{{message.role === 'user'}}" class="bubble user-bubble">
    <t-tag
      wx:if="{{message.attachment}}"
      size="small"
      variant="light"
      theme="primary"
      class="attach-tag"
    >{{attachmentText}}</t-tag>
    <text class="content" user-select>{{message.content}}</text>
  </view>

  <!-- 助手消息 -->
  <view wx:else class="bubble assistant-bubble">
    <view wx:if="{{message.pending}}" class="pending">
      <t-loading theme="circular" size="40rpx" />
      <text class="pending-text">正在整理回答…</text>
    </view>

    <block wx:elif="{{message.kind === 'expense_log' || message.kind === 'budget_guard' || message.kind === 'progress_track'}}">
      <t-tag size="small" variant="outline" theme="default">即将上线</t-tag>
      <text class="content">{{message.content}}</text>
    </block>

    <block wx:else>
      <view class="meta-row">
        <t-tag
          wx:if="{{message.grounded && !message.error}}"
          size="small"
          theme="success"
          variant="light"
        >来自你的知识库</t-tag>
        <t-tag
          wx:elif="{{!message.error}}"
          size="small"
          theme="warning"
          variant="light"
        >没找到你的知识依据，仅供参考</t-tag>
        <t-tag
          wx:if="{{message.hasDocument}}"
          size="small"
          variant="light"
        >已结合报价单</t-tag>
      </view>
      <text class="content" user-select>{{message.content}}</text>
      <view
        wx:if="{{message.citations && message.citations.length}}"
        class="citations"
      >
        <view class="citations-toggle" bindtap="toggleCitations">
          {{showCitations ? '收起依据' : '查看依据'}}
        </view>
        <view wx:if="{{showCitations}}" class="citation-list">
          <view
            wx:for="{{message.citations}}"
            wx:key="id"
            class="citation-item"
          >
            <text class="citation-title">{{item.title}}</text>
            <text class="citation-excerpt">{{item.excerpt}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
