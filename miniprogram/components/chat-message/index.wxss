.chat-message {
  margin-bottom: 28rpx;
  display: flex;
}

.chat-message.user {
  justify-content: flex-end;
}

.bubble {
  max-width: 86%;
  padding: 22rpx 26rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
}

.user-bubble {
  background: #ff6b4a;
  border-bottom-right-radius: 8rpx;
}

.user-bubble .content {
  color: #fff;
}

.assistant-bubble {
  background: #ffffff;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
}

.attach-tag {
  margin-bottom: 12rpx;
}

.content {
  display: block;
  white-space: pre-wrap;
  line-height: 1.65;
  color: #1f2937;
  font-size: 28rpx;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.badge {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.badge-ok {
  background: #ecfdf5;
  color: #059669;
}

.badge-warn {
  background: #fffbeb;
  color: #d97706;
}

.badge-doc {
  background: #eff6ff;
  color: #2563eb;
}

.pending {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pending-text {
  color: #6b7280;
  font-size: 26rpx;
}

.citations-toggle {
  margin-top: 16rpx;
  color: #ff6b4a;
  font-size: 26rpx;
}

.citation-item {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.citation-title {
  display: block;
  font-weight: 600;
  font-size: 26rpx;
}

.citation-excerpt {
  display: block;
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
}
