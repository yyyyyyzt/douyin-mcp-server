.chat-message {
  margin-bottom: 24rpx;
  display: flex;
}

.chat-message.user {
  justify-content: flex-end;
}

.bubble {
  max-width: 88%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.user-bubble {
  background: #ffede8;
}

.assistant-bubble {
  background: #ffffff;
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.06);
}

.attach-tag {
  margin-bottom: 12rpx;
}

.content {
  display: block;
  white-space: pre-wrap;
  line-height: 1.6;
  color: #1f2937;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.pending {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pending-text {
  color: #6b7280;
  font-size: 26rpx;
}

.citations-toggle {
  margin-top: 16rpx;
  color: #ff6b4a;
  font-size: 26rpx;
}

.citation-item {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 16rpx;
}

.citation-title {
  display: block;
  font-weight: 600;
  font-size: 26rpx;
}

.citation-excerpt {
  display: block;
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
}
