.login-guard {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  flex: 1;
  min-height: 60vh;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

.brand {
  font-size: 56rpx;
  font-weight: 700;
  color: #ff6b4a;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.headline {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 56rpx;
}

.config-hint {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: #fff7ed;
  border-radius: 16rpx;
  color: #c2410c;
  font-size: 26rpx;
  line-height: 1.55;
}

.api-hint {
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: #9ca3af;
  word-break: break-all;
}

.error {
  margin-top: 24rpx;
  color: #d97706;
  font-size: 26rpx;
}

.login-btn {
  margin: 0;
  background: #ff6b4a;
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 96rpx;
  height: 96rpx;
  border: none;
}

.login-btn::after {
  border: none;
}
