.login-guard {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: center;
  flex: 1;
  min-height: 60vh;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

.brand {
  font-size: 56rpx;
  font-weight: 700;
  color: #ff6b4a;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.headline {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.profile-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-picker {
  margin: 0 0 32rpx;
  padding: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f3f4f6;
  border: 2rpx dashed #d1d5db;
}

.avatar-picker::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
}

.avatar-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.avatar-hint {
  font-size: 22rpx;
}

.nickname-row {
  width: 100%;
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #f9fafb;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.nickname-label {
  flex-shrink: 0;
  width: 88rpx;
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.nickname-input {
  flex: 1;
  font-size: 30rpx;
  color: #111827;
}

.error {
  margin-top: 24rpx;
  color: #d97706;
  font-size: 26rpx;
  text-align: center;
}

.login-btn {
  margin: 0;
  background: #ff6b4a;
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 96rpx;
  height: 96rpx;
  border: none;
}

.login-btn::after {
  border: none;
}
