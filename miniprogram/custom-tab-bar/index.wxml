<!-- 原生自定义 tabBar：不用 TDesign 图标字体，避免字体加载失败 -->
<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="value"
    class="tab-item {{value === item.value ? 'active' : ''}}"
    data-value="{{item.value}}"
    bindtap="onTap"
  >
    <view class="tab-glyph">{{item.glyph}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
