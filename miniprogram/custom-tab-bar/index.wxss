.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: stretch;
  height: calc(110rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  background: #ffffff;
  border-top: 1rpx solid rgba(15, 23, 42, 0.08);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #9ca3af;
}

.tab-item.active {
  color: #ff6b4a;
}

.tab-glyph {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 600;
}

.tab-text {
  font-size: 22rpx;
  line-height: 1.2;
}
