# 复制为 .env 并填入真实密钥（.env 已在 .gitignore 中，勿提交）
# 硅基流动 API Key：https://cloud.siliconflow.cn/

# 语音识别（ASR）密钥；LLM 未单独配置时与此共用
API_KEY=sk-your-api-key-here

# 可选：单独配置 LLM 密钥（不填则使用 API_KEY）
# LLM_API_KEY=

# LLM 接口（OpenAI 兼容）
LLM_BASE_URL=https://api.siliconflow.cn/v1

# 默认模型（用户可在界面覆盖）
LLM_MODEL=Qwen/Qwen3-8B
ASR_MODEL=FunAudioLLM/SenseVoiceSmall

# 可选
# LLM_TIMEOUT=60
# LLM_MAX_RETRIES=3
# KNOWLEDGE_DB=data/knowledge.db
# CHAT_MIN_SCORE=0.0
# PORT=8080

# 可选：超级管理员令牌。配置后，提示词调试 API 需在请求头携带 X-Admin-Token
# ADMIN_TOKEN=your-admin-token

# 可选：自定义提示词文件路径（默认 data/prompts.json）
# PROMPTS_FILE=data/prompts.json

# —— 微信小程序 / 多用户（见 docs/DESIGN.md）——
# WECHAT_APPID=
# WECHAT_SECRET=
# SESSION_SECRET=change-me-to-a-long-random-string
# 仅本地 / 自托管 Web 兼容登录；生产小程序环境请保持 0 或未设置
ALLOW_LOCAL_AUTH=1
